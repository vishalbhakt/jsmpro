DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.onrender.com
DJANGO_TIME_ZONE=Asia/Kolkata
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# Option 1: single URL for Render/Railway PostgreSQL
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Option 2: individual PostgreSQL values
# POSTGRES_DB=jsm_shiksha
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
